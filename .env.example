# Cairn Backend Environment Configuration

# Server Configuration
CAIRN__SERVER__HOST=0.0.0.0
CAIRN__SERVER__PORT=8080

# Database Configuration
CAIRN__DATABASE__URL=postgresql://user:password@localhost:5432/cairn

# Redis Configuration
CAIRN__REDIS__URL=redis://localhost:6379

# JWT Configuration
# Generate secure secrets with: openssl rand -base64 64
CAIRN__JWT__SECRET=your-jwt-secret-change-this-in-production
CAIRN__JWT__EXPIRY_MINUTES=15
CAIRN__JWT__REFRESH_SECRET=your-refresh-secret-change-this-too
CAIRN__JWT__REFRESH_EXPIRY_DAYS=7

# OAuth Configuration (optional - Phase 2)
CAIRN__OAUTH__GOOGLE_CLIENT_ID=
CAIRN__OAUTH__GOOGLE_CLIENT_SECRET=
CAIRN__OAUTH__GITHUB_CLIENT_ID=
CAIRN__OAUTH__GITHUB_CLIENT_SECRET=
CAIRN__OAUTH__REDIRECT_BASE=http://localhost:8080

# Invite System Configuration
# Generate a secure salt with: openssl rand -base64 32
CAIRN__INVITE__SALT=your-invite-salt-change-this
CAIRN__INVITE__REQUIRE_INVITE=true

# SMTP Configuration (optional - for email verification)
CAIRN__SMTP__HOST=smtp.example.com
CAIRN__SMTP__PORT=587
CAIRN__SMTP__USER=
CAIRN__SMTP__PASSWORD=
CAIRN__SMTP__FROM_EMAIL=noreply@cairn.local

# Rate Limiting Configuration
CAIRN__RATE_LIMIT__LOGIN_PER_MINUTE=5
CAIRN__RATE_LIMIT__REGISTER_PER_HOUR=3
CAIRN__RATE_LIMIT__FORGOT_PASSWORD_PER_HOUR=3
CAIRN__RATE_LIMIT__INVITE_VALIDATE_PER_MINUTE=10
CAIRN__RATE_LIMIT__AUTHENTICATED_PER_MINUTE=60

# Run Mode (development, production)
RUN_MODE=development
